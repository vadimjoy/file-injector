{
  "name": "ai-css-kit",
  "version": "0.3.0",
  "description": "Modern modular CSS component library with tokens, themes, and demo blocks.",
  "main": "dist/pure-ui.css",
  "style": "dist/pure-ui.css",
  "files": [
    "dist",
    "src/css",
    "src/demos",
    "src/js/demo-theme.js",
    "README.md",
    "SPEC.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "style": "./dist/pure-ui.css",
      "default": "./dist/pure-ui.css"
    },
    "./tokens": "./src/css/tokens.css",
    "./base": "./src/css/base.css",
    "./components/*": "./src/css/components/*.css"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build:css": "postcss src/css/index.css -o dist/pure-ui.css",
    "build:css:min": "cross-env NODE_ENV=production postcss src/css/index.css -o dist/pure-ui.min.css",
    "build": "npm run clean && npm run build:css && npm run build:css:min",
    "prepare": "npm run build"
  },
  "keywords": [
    "css",
    "components",
    "design-system",
    "tokens",
    "theming",
    "pure"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vadimjoy/pure-ui.git"
  },
  "author": "Vadim Joy",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vadimjoy/pure-ui/issues"
  },
  "homepage": "https://github.com/vadimjoy/pure-ui#readme",
  "dependencies": {
    "font-awesome": "^4.7.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "cssnano": "^6.1.2",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^12.1.4",
    "rimraf": "^5.0.5"
  }
}
