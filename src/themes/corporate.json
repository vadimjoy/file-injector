{
  "meta": {
    "name": "Corporate",
    "version": "1.0.0",
    "description": "Clean, neutral corporate theme — blue accent, square corners, system sans-serif"
  },
  "tokens": {
    "font.family":              "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji'",
    
    "color.primary":            "#2563eb",
    "color.primary.hover":      "#1d4ed8",
    "color.primary.soft":       "rgba(37, 99, 235, 0.10)",
    "color.primary.light":      "#eff6ff",

    "color.success":            "#059669",
    "color.success.soft":       "rgba(5, 150, 105, 0.10)",
    "color.success.light":      "#ecfdf5",

    "color.warning":            "#b45309",
    "color.warning.soft":       "rgba(180, 83, 9, 0.10)",
    "color.warning.light":      "#fffbeb",

    "color.error":              "#b91c1c",
    "color.error.soft":         "rgba(185, 28, 28, 0.10)",
    "color.error.light":        "#fef2f2",

    "color.border":             "#d1d5db",
    "color.border.strong":      "#9ca3af",
    "color.border.focus":       "#2563eb",

    "color.bg":                 "#ffffff",
    "color.bg.subtle":          "#f8fafc",
    "color.bg.hover":           "#f1f5f9",
    "color.bg.disabled":        "#f8fafc",
    "color.bg.overlay":         "rgba(0, 0, 0, 0.03)",

    "color.text":               "#0f172a",
    "color.text.secondary":     "#334155",
    "color.text.muted":         "#64748b",
    "color.text.disabled":      "#94a3b8",
    "color.text.placeholder":   "#94a3b8",

    "radius.xs":                "2px",
    "radius.sm":                "3px",
    "radius.md":                "4px",
    "radius.lg":                "6px",
    "radius.xl":                "8px",
    "radius.full":              "9999px",

    "shadow.xs":                "0 1px 2px rgba(0, 0, 0, 0.05)",
    "shadow.sm":                "0 1px 3px rgba(0, 0, 0, 0.10), 0 1px 2px rgba(0, 0, 0, 0.06)",
    "shadow.md":                "0 4px 6px -1px rgba(0, 0, 0, 0.10), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
    "shadow.lg":                "0 10px 15px -3px rgba(0, 0, 0, 0.10), 0 4px 6px -2px rgba(0, 0, 0, 0.05)"
  }
}
