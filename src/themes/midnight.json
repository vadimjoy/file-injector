{
  "meta": {
    "name": "Midnight",
    "version": "1.0.0",
    "description": "Deep dark theme with violet/purple accent and monospace font"
  },
  "tokens": {
    "font.family":              "ui-monospace, 'Courier New', 'Liberation Mono', Consolas, monospace",

    "color.primary":            "#8b5cf6",
    "color.primary.hover":      "#7c3aed",
    "color.primary.soft":       "rgba(139, 92, 246, 0.18)",
    "color.primary.light":      "rgba(139, 92, 246, 0.10)",

    "color.success":            "#34d399",
    "color.success.soft":       "rgba(52, 211, 153, 0.15)",
    "color.success.light":      "rgba(52, 211, 153, 0.08)",

    "color.warning":            "#fbbf24",
    "color.warning.soft":       "rgba(251, 191, 36, 0.15)",
    "color.warning.light":      "rgba(251, 191, 36, 0.08)",

    "color.error":              "#f87171",
    "color.error.soft":         "rgba(248, 113, 113, 0.15)",
    "color.error.light":        "rgba(248, 113, 113, 0.08)",

    "color.border":             "#2d2b55",
    "color.border.strong":      "#3d3b6b",
    "color.border.focus":       "#8b5cf6",

    "color.bg":                 "#13111e",
    "color.bg.subtle":          "#0d0c17",
    "color.bg.hover":           "#1e1b30",
    "color.bg.disabled":        "#13111e",
    "color.bg.overlay":         "rgba(255, 255, 255, 0.04)",

    "color.text":               "#e2e8f0",
    "color.text.secondary":     "#cbd5e1",
    "color.text.muted":         "#8892a4",
    "color.text.disabled":      "#3d3b6b",
    "color.text.placeholder":   "#5a5a7a",

    "radius.xs":                "3px",
    "radius.sm":                "5px",
    "radius.md":                "8px",
    "radius.lg":                "12px",
    "radius.xl":                "16px",

    "shadow.xs":                "0 1px 2px rgba(0, 0, 0, 0.50)",
    "shadow.sm":                "0 1px 3px rgba(0, 0, 0, 0.60), 0 1px 2px rgba(0, 0, 0, 0.50)",
    "shadow.md":                "0 4px 6px -1px rgba(0, 0, 0, 0.60), 0 2px 4px -1px rgba(0, 0, 0, 0.50)",
    "shadow.lg":                "0 10px 15px -3px rgba(0, 0, 0, 0.70), 0 4px 6px -2px rgba(0, 0, 0, 0.50)",

    "calendar.selected-bg":     "#8b5cf6",
    "button.focus-ring":        "rgba(139, 92, 246, 0.30)"
  }
}
